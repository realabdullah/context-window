{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": { "~/*": ["./src/*"] }
  },
  "include": ["src/**/*", "app/**/*", "*.config.ts"],
  "exclude": ["node_modules", "dist", ".output"]
}
