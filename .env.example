# PostgreSQL connection string (used by Prisma in packages/database and apps/api)
DATABASE_URL="postgresql://user:password@localhost:5432/context_window?schema=public"

# Optional: API port (default 3001)
# PORT=3001

# GitHub OAuth (apps/api) - required for Auth. Create at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Session & CORS (apps/api)
# SESSION_SECRET=  # optional for now; used if we sign cookies later
# FRONTEND_URL=http://localhost:3000   # Vite web app; use http://localhost:3002 when using Next.js app

# Web app (apps/web): optional, defaults to http://localhost:3001 and mvp-user-1
# VITE_API_URL=http://localhost:3001
# VITE_USER_ID=mvp-user-1

# Next.js app (apps/nextjs-web): optional; API URL defaults to http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001

# LLM providers (apps/api) - at least one required for Compile. Never expose to client.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=  # Kimi (Moonshot AI) - https://api.moonshot.cn
